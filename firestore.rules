rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Allow read and write access to the books collection
    match /books/{bookId} {
      // Allow anyone to read books (for searching and browsing)
      allow read: if true;
      
      // Allow anyone to write books (for adding, updating, borrowing, returning)
      allow write: if true;
    }
    
    // Allow read and write access to the transactions collection
    match /transactions/{transactionId} {
      // Allow anyone to read transactions (for viewing history)
      allow read: if true;
      
      // Allow anyone to write transactions (for borrowing and returning)
      allow write: if true;
    }
    
    // Block access to any other collections by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
